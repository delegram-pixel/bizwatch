    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-session": "^1.18.1",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^6.0.0"
  },
