# Neon PostgreSQL connection string
# Get this from your Neon project dashboard → Connection Details
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx-xxx.us-east-1.aws.neon.tech/bizwatch?sslmode=require

# Google OAuth credentials
# Create these at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=goes here
GOOGLE_CLIENT_SECRET=goes jere
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Session secret — use any long random string in production
SESSION_SECRET=change_this_to_a_long_random_string

PORT=3000

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173

# Claude API key (same one used in the frontend .env)
CLAUDE_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX