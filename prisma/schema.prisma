generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  googleId     String    @unique
  email        String    @unique
  name         String
  picture      String?
  accessToken  String?
  refreshToken String?
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id         String   @id
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  data       Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime?
}
