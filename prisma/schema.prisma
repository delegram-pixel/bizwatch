generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  googleId     String    @unique
  email        String    @unique
  name         String
  picture      String?
  accessToken  String?
  refreshToken String?
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id         String   @id
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  data       Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime?
}

model Analysis {
  id        String   @id @default(cuid())
  userId    String
  result    Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Invoice {
  id          String    @id @default(cuid())
  userId      String
  reference   String
  client      String
  amount      Float
  currency    String    @default("NGN")
  dueDate     DateTime?
  status      String    @default("unpaid")
  sourceFile  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, reference])
  @@index([userId, status])
}
